<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Discover Amazing Products</h1>
      <p>Shop the latest trends at unbeatable prices</p>
      <a href="/products" class="btn btn-primary">Shop Now</a>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Featured Products</h2>
      <div class="product-grid">
        <% featured.forEach(product => { %>
          <div class="product-card">
            <img src="<%= product.image %>" alt="<%= product.name %>" onerror="this.onerror=null; this.src='https://placehold.co/400x220?text=No+Image'" />
            <div class="product-info">
              <span class="category"><%= product.category %></span>
              <h3><%= product.name %></h3>
              <p class="price">$<%= product.price.toFixed(2) %></p>
              <a href="/products/<%= product.id %>" class="btn btn-outline">View Details</a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>